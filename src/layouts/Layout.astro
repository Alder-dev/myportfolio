---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import "flowbite";
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portafolio - Alder Andrés - Desarrollador</title>
    <meta name="description" content="Portafolio de Alder Andrés Palacios, Ingeniero de Sistemas y Desarrollador Full Stack. Conoce mis proyectos, experiencia y habilidades en tecnología." />
    <meta name="author" content="Alder Andrés Palacios" />
    <meta name="keywords" content="Desarrollador, Full Stack, Ingeniero de Sistemas, Astro, React, Python, Backend, Frontend" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://alderdev-portfolio.netlify.app/" /> <!-- Ajustar si hay dominio propio -->
    <meta property="og:title" content="Portafolio - Alder Andrés" />
    <meta property="og:description" content="Descubre mis proyectos, experiencia laboral y habilidades como Desarrollador Full Stack." />
    <meta property="og:image" content="/img/alderph.jpg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://alderdev-portfolio.netlify.app/" />
    <meta property="twitter:title" content="Portafolio - Alder Andrés" />
    <meta property="twitter:description" content="Descubre mis proyectos, experiencia laboral y habilidades como Desarrollador Full Stack." />
    <meta property="twitter:image" content="/img/alderph.jpg" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="relative bg-neutral-950 text-white min-h-screen flex flex-col overflow-x-hidden">
    <script is:inline src="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js"></script>

    <!-- Fondo radial decorativo -->
    <div
      class="absolute inset-0 -z-10 w-full h-full bg-[radial-gradient(ellipse_100%_80%_at_50%_0%,rgba(20,100,150,0.3),transparent)]"
    >
    </div>

    <!-- Header -->
    <Header />

    <!-- Contenido dinámico -->
    <main
      class="flex-grow w-full px-4 sm:px-6 md:px-8 xl:px-0 xl:max-w-[1120px] mx-auto"
    >
      <slot />
    </main>

    <!-- Footer -->
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
  }

  html {
    font-family: "Onest Variable", system-ui, sans-serif;
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    html {
      scroll-behavior: auto;
    }
  }
</style>
